# ===== App config =====
APP_PASSWORD=cheese

# ===== qBittorrent =====
# These serve as initial defaults. Once configured via the Settings page (/settings),
# the values in secrets/settings.json take precedence over these env vars.
APP_QB_URL=http://qbittorrent:8080
APP_QB_USERNAME=admin
APP_QB_PASSWORD=adminadmin

# ===== MAM auth =====
APP_MAM_USER_AGENT=Scurry/2.0 (+contact)

# ===== Mousehole Integration (Optional) =====
# Enable dynamic MAM token management via mousehole
# See docs/MOUSEHOLE.md for setup instructions
MOUSEHOLE_ENABLED=false
MOUSEHOLE_STATE_FILE=secrets/state.json
