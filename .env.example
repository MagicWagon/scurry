# ===== App config =====
APP_PASSWORD=cheese
APP_QB_URL=http://qbittorrent:8080
# Legacy fallback for book downloads if APP_QB_BOOK_CATEGORY is not set.
APP_QB_CATEGORY=books
APP_QB_BOOK_CATEGORY=books
APP_QB_AUDIOBOOK_CATEGORY=audiobooks
APP_QB_USERNAME=admin
APP_QB_PASSWORD=adminadmin

# books, audiobooks, or both
APP_DEFAULT_SEARCH_CATEGORY=books
APP_PREFER_EPUB_ONLY=false
APP_PREFER_M4B=false

# ===== MAM auth =====
APP_MAM_USER_AGENT=Scurry/2.0 (+contact)

# ===== Mousehole Integration (Optional) =====
# Enable dynamic MAM token management via mousehole
# See docs/MOUSEHOLE.md for setup instructions
MOUSEHOLE_ENABLED=false
MOUSEHOLE_STATE_FILE=secrets/state.json

# ===== Legacy browser-exposed defaults (deprecated) =====
# Runtime Docker config uses APP_DEFAULT_SEARCH_CATEGORY instead.
# NEXT_PUBLIC_DEFAULT_CATEGORY=books
